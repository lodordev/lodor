    "gb":  { "slug": "gb",  "relative_path": "Roms/Game Boy (GB)" },
    "nes": { "slug": "nes", "relative_path": "Roms/Nintendo Entertainment System (FC)" },
    "snes":{ "slug": "snes","relative_path": "Roms/Super Nintendo (SUPA)" },
    "psx": { "slug": "psx", "relative_path": "Roms/Sony PlayStation (PS)" }
  },
  "api_timeout": 30,
  "download_timeout": 3600
